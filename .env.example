PORT=3000
TARIFF_CONFIG_PATH=config/tariffs/moscow-test.json
# Локально (docker compose / Redpanda):
# KAFKA_BROKERS=localhost:9092
#
# Внешний Kafka (из интернета):
# KAFKA_BROKERS=94.139.255.96:9094
#
# Во внутренней сети VM (предпочтительно при запуске из VM):
# KAFKA_BROKERS=10.50.0.20:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=fare-worker
KAFKA_GROUP_ID=fare-worker-group-v1
KAFKA_CONNECTION_TIMEOUT_MS=10000
KAFKA_REQUEST_TIMEOUT_MS=60000
KAFKA_RETRIES=100000
KAFKA_INITIAL_RETRY_MS=1000
KAFKA_MAX_RETRY_MS=30000
KAFKA_TOPIC_INPUT=validations
KAFKA_TOPIC_RESULT=fare.calculation.result.v1
KAFKA_TOPIC_FAILED=fare.calculation.failed.v1
KAFKA_TOPIC_DLQ=fare.calculation.dlq.v1
