{
  "name": "moscow-fare-calculator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:api": "tsx src/api/server.ts",
    "dev:worker": "KAFKA_BROKERS=94.139.255.96:9094 KAFKA_TOPIC_INPUT=validations tsx src/kafka/worker.ts",
    "dev:worker:vm": "KAFKA_BROKERS=10.50.0.20:9092 KAFKA_TOPIC_INPUT=validations tsx src/kafka/worker.ts",
    "dev:web": "npm --prefix apps/web run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "build:web": "npm --prefix apps/web run build",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "kafkajs": "^2.2.4",
    "kafkajs-snappy": "^1.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/express": "^4.17.23",
    "@types/node": "^20.17.32",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vitest": "^2.1.8"
  }
}
